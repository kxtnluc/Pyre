@namespace Pyre.Element.Form

<div class="form__cell" style="flex: @FlexValue">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Ratio { get; set; } = "1/2";

    private string FlexValue
    {
        get
        {
            var parts = Ratio.Split('/');
            if (parts.Length == 2 &&
                int.TryParse(parts[0], out int num) &&
                int.TryParse(parts[1], out int den))
            {
                return ((double)num / den).ToString("F4", System.Globalization.CultureInfo.InvariantCulture);
            }
            return "1"; // fallback to equal width
        }
    }
}