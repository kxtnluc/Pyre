@namespace Pyre.Element.Modal
@using Pyre.Element.Button
@using Pyre.Element.Icons

@if (Open)
{
    <div class="modal__overlay" @onclick="LeaveModal">
        <div class="@ComputedClass" @onclick:stopPropagation>
            <div class="modal__header">
                <div class="modal__title__container">
                    <div class="modal__title">@Title</div>
                    @if (HelpBtn)
                    {
                        <button class="modal--help--btn"><QuestionIcon Size="16" Variant="E_QUESTION_ICON.Lightbulb" /></button>                 
                    }
                </div>
                <div class="modal__close">
                    @if (Closeable)
                    {
                        <button class="modal--close--btn" @onclick="LeaveModal"><XIcon Size="12" /></button>
                    }
                </div>
            </div>
            <div class="modal__body">
                @ChildContent
            </div>
            <div>
                @switch (Variant)
                {
                    case E_MODAL.Unset:
                        break;
                    case E_MODAL.AddEdit:
                        break;
                    case E_MODAL.Delete:
                        <div class="modal--footer--content">
                            <Button Variant="E_VARIANT.Primary" Color="E_COLOR_BASIC.Remove">Delete</Button>
                            <Button Variant="E_VARIANT.Secondary" Color="E_COLOR_BASIC.OffWhite" Onclick="LeaveModal">Cancel</Button>
                        </div>
                        break;
                    case E_MODAL.Info:
                        <div class="modal--footer--content">
                            <Button Variant="E_VARIANT.Primary" Color="E_COLOR_BASIC.Info">Ok</Button>
                        </div>
                        break;
                    case E_MODAL.Warning:
                        <div class="modal--footer--content">
                            <Button Variant="E_VARIANT.Primary" Color="E_COLOR_BASIC.Remove">I Understand</Button>
                            <Button Variant="E_VARIANT.Secondary" Color="E_COLOR_BASIC.OffWhite" Onclick="LeaveModal">Cancel</Button>
                        </div>
                        break;
                }
            </div>
        </div>
    </div>
}

@code {
    // Base
    [Parameter] public bool Open { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
    [Parameter] public string Title { get; set; } = "";
    // Pyre Base {
    [Parameter] public E_MODAL Variant { get; set; } = E_MODAL.Unset;
    [Parameter] public E_SIZE Size { get; set; } = E_SIZE.md;
    [Parameter] public bool Closeable { get; set; } = true;
    [Parameter] public bool HelpBtn { get; set; } = false;
    // |
    private string _variant => Variant.ToString().ToLower();
    private string _size => Size.ToString().ToLower();
    private string _closeable => Closeable.ToString().ToLower();
    private string _helpBtn => HelpBtn.ToString().ToLower();
    // }
    // ========================================================================================================================================
    // Logic Handling
    private async Task LeaveModal()
    {
        if (Closeable)
        {
            if (OnClose.HasDelegate)
                await OnClose.InvokeAsync();
        }
    }
    // ========================================================================================================================================
    // Computed Classes & Styles
    private string ComputedClass =>
        $"modal__card modal--size--{_size} modal--footer--variant--{_variant}";

    private string ComputedStyle =>
        $"";
}